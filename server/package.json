{
  "name": "starbite-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "predev": "npm run build --workspace=starbite-shared",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prestart": "npm run build --workspace=starbite-shared",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@colyseus/core": "^0.16.0",
    "@colyseus/monitor": "^0.16.0",
    "@colyseus/schema": "^3.0.0",
    "@colyseus/ws-transport": "^0.16.0",
    "colyseus": "^0.16.0",
    "express": "^4.21.0",
    "starbite-shared": "*"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
